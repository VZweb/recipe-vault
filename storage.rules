rules_version = '2';
// Narrative: docs/security.md
service firebase.storage {
  match /b/{bucket}/o {
    match /recipes/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /pantry/{uid}/{itemId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
