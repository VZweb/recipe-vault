rules_version = '2';
// Narrative: docs/security.md
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    /** Set via Admin SDK: `node scripts/set-catalog-admin-claim.mjs --uid=...` */
    function isCatalogAdmin() {
      return signedIn() && request.auth.token.catalogAdmin == true;
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/recipes/{recipeId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/pantry/{pantryId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/tags/{tagId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/categories/{categoryId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/customIngredients/{ingredientId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    // TODO: tighten if you add moderation tools — for now only catalogAdmin may write.
    match /ingredientCatalog/{ingredientId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && isCatalogAdmin();
    }
  }
}
